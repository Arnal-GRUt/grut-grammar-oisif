---
// import Tag from "../pages/tags/[tag].astro";
// import PostTags from "../components/postTags.astro";
const { title, url, pubDate, author, contexte, description, blueskyUri } =
    Astro.props;
// import arrow from "../images/arrow-right-svg.svg";
---

<a class="lien-post-last" href={url}>
    
    <div class="display-flex direction-column presentation">        
        <div class="display-flex carton-presentation direction-column">
            <p class="date-et-auteur">
                <time datetime={pubDate}
                    >{
                        new Date(pubDate).toLocaleDateString("fr-FR", {
                            year: "numeric",
                            month: "short",
                            day: "numeric",
                        })
                    }</time
                >
                <span>|</span><span class="auteur">{author}</span>
            </p>
            <p class="sous-titre">Le dernier texte</p>
            <p class="sub-title">Titre</p>
            <p class="last-pub">{title}</p>
            <p class="sub-title">Description</p>
            <p class="last-pub-desc">{description}</p>
        </div>
    </div>
</a>
<style>
    .lien-post-last .display-flex.direction-column.presentation {
        background: transparent;
        min-width: 460px;
        & p {
            transform: unset;
        }
    }
    .lien-post-last {
        padding: 16px;
        & .carton-presentation.direction-column {
            width: 65%;
            transition: 0.2s;
            &:hover {
                transform: rotate(0deg);
            }
            & p {
                color: var(--black);
            }
        }
        & .date-et-auteur {
            font-size: 1rem;
        }
        & p:is(.sous-titre, .sub-title) {
            font-family: chelsea market;
            text-decoration: underline;
            padding: 0.5rem 0;
        }
        & .sub-title,
        p[class*="last-pub"] {
            font-size: 1.2rem;
        }
        & .presentation.display-flex.direction-column {
            padding: 0;

            & .carton-presentation.direction-column {
                background: var(--yellow);
            }
        }
    }

    .lien-post-last .carton-presentation.direction-column {
        width: calc(100% - 32px);
        transform: rotate(-3deg);
        position: relative;
        transition: 0.2s;
        
        &:hover {
            transform: rotate(0deg);
        }
    }

    @media (width < 769px) {
        .lien-post-last {
            padding-left: 0;
            & .carton-presentation.direction-column {
                width: calc(100% - 32px);
                transform: rotate(-3deg);
                position: relative;
                transition: 0.2s;
                &:hover {
                    transform: rotate(0deg);
                }
                &::before {
                    content: "";
                    position: absolute;
                    width: 4rem;
                    height: 4rem;
                    background: url(../images/arrow-bottom-right.png);
                    background-size: contain;
                    background-position: center;
                    background-repeat: no-repeat;
                    /* mask: image(url("../images/arrow-bottom-right.png"), var(--black));                                                                 */
                    /* mask-image: url({arrow});                                                                 */
                    /* mask-repeat: no-repeat;
                    mask-position: center;
                    mask-size: contain; */
                    /* background: var(--black); */
                    z-index: 1;
                    top: -30%;
                }
            }
        }
    }
</style>
