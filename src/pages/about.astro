---
import BaseLayout from "../layouts/BaseLayout.astro";
// import BlogPost from "../components/BlogPost.astro";
const pageTitle = "about La vie, les potos et le reste";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="contenu-page display-flex direction-row">
    <section>
      <h1 class="soustitre-page">{pageTitle.slice(6)}</h1>
      <div class="main-potos display-flex">
        <h2 class="soustitre-page">Un peu de passif</h2>
        <ul>
          <li>
            Y'a longtemps j'ai fait la bouffe dans des restos et servi des cafés
            dans un cybercafé.
          </li>
          ///
          <ul>
            <li>Durant tout ce temps j'ai fait de la musique avec des amis,</li>
            <li>j'ai joué à CS et fait du JDR avec d'autres copains,</li>
            <li>j'ai commencé pleins de choses à la fac,</li>
            <li>j'ai quasi rien validé.</li>
          </ul>
          ///
          <li>Plus tard en 2010, j'ai eu un DUT en informatique.</li>
          <li>En 2018, j'ai arrêté de faire le pion au lycée à Saintes.</li>
          <li>Encore après, je me suis formé au webdesign.</li>
          <li>Aujourd'hui, je suis webdesigner depuis 5 ans à Solocal.</li>
          <br />
          <li>Et surtout, surtout,</li>
          <li>j'ai passé beaucoup trop de temps sur Elden Ring</li>
        </ul>
        <h2 class="soustitre-page">Et sinon la vie</h2>
        <p>
          La bouffe, la fiction, la politique, le jdr et cie, le JV, le foot (à
          la tévé), la gribouille des autres, la musique des autres,
          <span class="icon"
            ><a target="_blank" href="https://bandcamp.com/arnalgrut"
              >mon profil bandcamp</a
            ></span
          >.
        </p>
      </div>
      <div class="main-potos display-flex">
        <h2 class="soustitre-page">Le taf des potos...</h2>
        <div class="display-flex direction-row presentation">
          <div class="display-flex">
            <h3 class="les-potos-ls">
              <a target="_blank" href="https://onehuman.fr/">Onehuman</a>
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-potos-am">
              <a target="_blank" href="https://marmoneur.netlify.app/"
                >Marmoneur</a
              >
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-potos-jj">
              <a
                target="_blank"
                href="https://audioblog.arteradio.com/blog/261344/lectus-podcast"
                >LectUs</a
              >
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-potos-sr">
              <a
                target="_blank"
                href="https://stefan-rooy-artworks.multiscreensite.com/"
                >Stefan Rooy</a
              >
            </h3>
          </div>
        </div>
      </div>
      <div class="main-potos display-flex">
        <h2 class="soustitre-page">Cadors non exhaustifs</h2>
        <div class="display-flex direction-row presentation">
          <div class="display-flex">
            <h3 class="les-cadors">
              <a target="_blank" href="https://www.bouletcorp.com/home"
                >Bouletcorps</a
              >
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-cadors">
              <a target="_blank" href="https://www.simonstalenhag.se/"
                >Simon Stalenhag</a
              >
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-cadors">
              <a target="_blank" href="https://www.utopiales.org/">Les Utos</a>
            </h3>
          </div>
          <div class="display-flex">
            <h3 class="les-cadors">
              <a target="_blank" href="https://www.ironmaiden.com/"
                >Up The Irons !</a
              >
            </h3>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
