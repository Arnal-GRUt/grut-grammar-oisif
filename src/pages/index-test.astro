---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
// import Background from "../images/grut-ville-2-1.png";
import Background from "../images/grut-ville-5.png";
import LastOne from "../components/LastPost.astro";

// import { Debug } from "astro:components";
const allPosts = Object.values(
	import.meta.glob("./posts/*.md", { eager: true }),
);
allPosts.sort(
	(a, b) =>
		Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate),
);

// const gribArt = import.meta.glob<{ default: ImageMetadata }>(
// 	"../images/artwork/*.{jpg,jpeg,JPG,png,webp}",
// );

const allArts = (await getCollection("grutArt")).sort(
	(a, b) => Date.parse(b.data.img_date) - Date.parse(a.data.img_date),
);

const pageTitle = "index-test";
---

<BaseLayout pageTitle={pageTitle}>
	<!-- <Debug {gribArt} /> -->
	<ul class="nav-secondaire nav-links">
		<li><a href="/Ecritouille">Écritouille</a></li>
		<li><a href="/gribouille">Gribouille</a></li>
		<!-- <li><a href="/webouille">Webouille</a></li> -->
		<li><a href="/about">La vie, le reste</a></li>
	</ul>
	<div class="carton-texte">
		<p>Portfolio & tutti quanti</p>
	</div>
	<div class="main">
		<div class="image-container">
			<Image
				class="image-reveal"
				src={Background}
				alt="Maison route et ville sur une montagne au loin"
			/>
		</div>
	</div>
	<div class="main-text display-flex direction-row">
		<div class="display-flex direction-row redirection-col">
			<div class="redirection-card-ecritouille">
				<div class="display-flex direction-row">
					<div class="presentation display-flex direction-column">
						<!-- <h2>L'écritouille</h2>
						<h3>Je publie des textes ici.</h3> -->
						<div class="ambiance display-flex direction-row">
							<div class="col-pres-publication">
								<h2>L'écritouille</h2>
								<h3>Je publie des textes ici.</h3>
								<p>
									Des nouvelles essentiellement mais aussi des
									articles, des listes, des poèmes, des écrits
									sans queue ni tête. De l'écritouille en
									somme, de la gribouille de texte, du doodle
									de mots, du crobar de phrases. Il y a du
									texte neuf, du vieux dont certains bien
									antérieurs à la création du blog. La plupart
									sont courts, voire très courts, et il est
									possible que, parfois, certains auront
									l’élégance de ne pas se terminer.
								</p>
								<p>
									Avant chaque publication je détaille parfois
									le mood et le cadre technique de la
									rédaction. Comme il s'agit souvent
									d'exercices, je donne le durée d'écriture,
									le mode de génération aléatoire des thèmes
									etc.<br /><br />Enfin bref, parce que j'ai
									envie de partager, <span class="style-h3"
										>je publie des textes ici.</span
									>
								</p>
								<div class="cta" style="align-items: flex-end;">
									<a href="/Ecritouille/">Clique et lis</a>
								</div>
							</div>
							<div class="col-last-pub">
								<!-- <p>Le dernier texte</p> -->
								{
									allPosts
										.slice(0, 1)
										.map((post: any) => (
											<LastOne
												url={post.url}
												title={post.frontmatter.title}
												pubDate={
													post.frontmatter.pubDate
												}
												author={post.frontmatter.author}
												title={post.frontmatter.title}
												contexte={
													post.frontmatter.contexte
												}
												description={
													post.frontmatter.description
												}
												enonce={post.frontmatter.enonce}
												tags={post.frontmatter.tags}
											/>
										))
								}
								<!-- <div class="cta" style="align-items: flex-end;">
									<a href="/Ecritouille/">Clique et lis</a>
								</div> -->
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- <div class="redirection-card-gribouille" style={`background="${art};"`}> -->
			<div class="redirection-card-gribouille">
				<div class="display-flex direction-column">
					{
						allArts
							.slice(0, 1)
							.map((art) => (
								<Image
									src={art.data.image.source}
									class="art-du-jour"
									alt={art.data.image.img_alt}
								/>
							))
					}
					<h2>La gribouille</h2>
					<p>
						Trad ou numérique. Trad et numérique. Des travaux
						terminés. D'autres à l'étape du crowbar. Du neuf, du
						vieux.
					</p>
					<div class="cta">
						<a href="/gribouille/">Clique ici</a>
					</div>
				</div>
			</div>
			<div class="redirection-card-webouille">
				<div class="display-flex direction-column">
					<h2>La webouille</h2>
					<p>
						Les étapes de création du projet "Grammar Oisif" -
						inspirations, choix techniques, expérimentations design,
						ressources.
					</p>
					<p>Bientôt...</p>
				</div>
			</div>
			<!-- <div class="cta"><a href="/webouille/">Click ici</a></div> -->
		</div>
	</div>
</BaseLayout>
