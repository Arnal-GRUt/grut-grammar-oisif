---
import BaseLayout from "../layouts/BaseLayout.astro";
// import BlogPost from "../components/BlogPost.astro";

const pageTitle = "Webouille";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="contenu-page display-flex">
    <section class="webouille-todo display-flex" style="background-color: var(--black);">
      <h1 class="soustitre-page">{pageTitle}</h1>
      <div class="display-flex">
        <h2 class="soustitre-page">Un peu de passif</h2>
        <ul>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
          <li>lorem ipsum - task 1</li>
        </ul>
      </div>    
    </section>
    <section class="webouille-done display-flex" style="background-color: var(--yellow);">
      <h1 class="soustitre-page">{pageTitle}</h1>
      <div class="display-flex">  
        <h2 class="soustitre-page">Et sinon la vie</h2>
        <p class="soustitre-page">Et sinon la vie</p>
      </div>      
    </section>
  </div>
</BaseLayout>
<style>
  section {
    width: 100%;
    z-index: 1;
  }
  
  .webouille-todo {
    width: 20%;
    height: 100vh;
    position: fixed;
  }
  .webouille-done {
    height: 100vh;
    width: auto;
    flex-grow: 1;
  }
  
  .contenu-page {
    position: relative;
    flex-direction: row;
    width: 100%;
    padding-top: 80px;
  }
</style>
