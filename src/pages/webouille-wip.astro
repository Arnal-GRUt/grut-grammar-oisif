        </p>
      </div>
    </section>
    <div class="overlay-done"></div>
  </div>
</BaseLayout>
<style>
  .webouille-main {
    position: relative;
    flex-direction: row;
    width: 100%;
    background: var(--black) url(../images/fond-webd.png);
    z-index: 1;
    background-size: cover;
    background-repeat: no-repeat;
    background-attachment: fixed;
    flex-wrap: wrap;
    & h1 {
      width: 100%;
      color: var(--white);
      z-index: 2;
      font-size: 4rem;
      margin-top: 66px;
      padding-left: 32px;
    }

    & div.overlay-done {
      content: "";
      position: absolute;
      /* width: 75%; */
      width: 100%;
      height: 45vh;
      background-image: linear-gradient(transparent 20%, var(--black));
      bottom: 0;
      right: 0;
      z-index: 1;
    }

    &:after {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      z-index: 0;
      background: var(--black);
      opacity: 0.85;
    }
  }
  section {
    z-index: 1;
    height: 100vh;
    padding-bottom: 15vh;
  }

  .webouille-todo {
    /* height: 100vh; */
    width: auto;
    max-width: 25%;
    /* background: var(--black); */
    & * {
      color: var(--white);
    }
    & > div {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: flex-start;
      padding: 2vh 32px 8vh 32px;
    }
    & ul {
      color: var(--white);
      width: inherit;
      padding: 0;

      & li input[checkbox] {
        display: flex;
      }
    }
  }
  .webouille-done {
    /* height: 100vh; */
    flex-grow: 1;
    width: auto;
    position: relative;
    max-width: 75%;
    & > div.main-done {
      max-width: 1280px;
      padding: 2vh 4vw 8vh 10vw;
      scrollbar-color: transparent transparent;
      overflow-y: scroll;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;

      & *:is(h2, h3, p) {
        max-width: 640px;
        height: auto;
      }
      & *:is(h2, h3) {
        background: var(--white);
        padding: 8px 16px 8px 0;
        color: var(--black);
        width: fit-content;
      }
      & *:is(h3, p) {
        font-size: 1.3rem;
      }
      & p {
        color: color-mix(in srgb, var(--white) 90%, var(--black));
      }
      & h2 {
        &:nth-child(even) {
          transform: rotate(2deg);
        }
        &:nth-child(odd) {
          transform: rotate(-2deg);
        }
      }
      & h3 {
        &:nth-child(even) {
          transform: rotate(-2deg);
        }
        &:nth-child(odd) {
          transform: rotate(2deg);
        }
      }
    }
  }
  @media (width < 1024px) {
    .webouille-main {
      position: relative;
      flex-direction: column;
      width: 100%;
      z-index: 1;
      background-size: cover;
      background-repeat: no-repeat;
      background-attachment: fixed;
      flex-wrap: wrap;

      & section {
        min-width: 100%;
        height: fit-content;        
      }
    }
  }
</style>
